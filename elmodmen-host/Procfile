web: sh -c 'F=$(find /app -name app.py -not -path "*/dist/*" -not -path "*/__pycache__/*" -not -path "*/site-packages/*" -not -path "*/data/*" 2>/dev/null | sort | head -1); [ -z "$F" ] && F=$(find . -name app.py -not -path "*/dist/*" -not -path "*/__pycache__/*" -not -path "*/data/*" 2>/dev/null | sort | head -1); cd "$(dirname "$F")"; exec gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --threads 8 --timeout 120'
